{
  "name": "prepare-apprunnerr-action",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "Preparing your App Runner before deployment",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "fix:lint": "eslint --fix \"src/**/*.ts\"",
    "package": "ncc build --source-map --license licenses.txt",
    "package:post": "ncc build lib/post-action.js --source-map --license licenses.txt -o dist/post",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm run package:post"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bervProject/prepare-apprunner-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@aws-sdk/client-apprunner": "^3.1090.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@vercel/ncc": "^0.44.1",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.1.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
